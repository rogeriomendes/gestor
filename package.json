{
  "name": "gestor",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "biome check --write .",
    "prepare": "husky",
    "ruler:apply": "pnpm dlx @intellectronica/ruler@latest apply --local-only",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @gestor/db db:push",
    "db:studio": "turbo -F @gestor/db db:studio",
    "db:generate": "turbo -F @gestor/db db:generate",
    "db:migrate": "turbo -F @gestor/db db:migrate",
    "db:gestor:studio": "turbo -F @gestor/db-gestor db:studio",
    "db:gestor:generate": "turbo -F @gestor/db-gestor db:generate",
    "db:dfe:studio": "turbo -F @gestor/db-dfe db:studio",
    "db:dfe:generate": "turbo -F @gestor/db-dfe db:generate"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.19.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "ultracite": "^7.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
